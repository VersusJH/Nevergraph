{
  "name": "nevergraph",
  "version": "0.1.0",
  "private": true,
  "description": "Turn collections of JSON objects into interactive, directed network graphs.",
  "type": "module",
  "scripts": {
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "dev": "pnpm run build:viewer && vite",
    "build": "pnpm run build:viewer && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cytoscape": "^3.30.4",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "dagre": "^0.8.5"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
